# ── AI Providers ─────────────────────────────────────────────
# Required: get from https://openrouter.ai/keys
OPENROUTER_API_KEY=
OLLAMA_HOST=http://host.docker.internal:11434

# ── App ──────────────────────────────────────────────────────
APP_TITLE=Vivian
DOMAIN=localhost
ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=false
ALLOW_SOCIAL_REGISTRATION=false

# ── Database ─────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017/librechat

# ── Secrets (app will not start without all four) ────────────
# Generate (64 hex chars): node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
CREDS_KEY=
# Generate (32 hex chars): node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
CREDS_IV=
